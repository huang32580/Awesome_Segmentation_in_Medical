{
  "name": "busi_UNet_experiment",
  "n_gpu": 1,
  "arch": {
    "type": "USFM_SegmentationModel",
    "args": {
      "in_channels": 1,
      "out_channels": 1
    }
  },
  "data": {
    "datasets": ["busi"],
    "force_prepare": false,
    "target_size": 224,
    "batch_size": 32,
    "num_workers": 8,
    "use_pad": false
  },
  "optimizer": {
    "type": "AdamW",
    "args": {
      "lr": 0.0001,
      "weight_decay": 1e-5
    }
  },
  "loss": {
    "type": "DiceBCELoss",
    "args": {}
  },
  "metrics": [
    "pixel_accuracy", "dice_score", "hd95_batch", "iou_score"
  ],
  "lr_scheduler": {
    "type": "CosineAnnealingLR",
    "args": {
      "T_max": 800,
      "eta_min": 1e-5
    }
  },
  "trainer": {
    "epochs": 800,
    "k_folds": 5,
    "checkpoint_dir": "checkpoints_debug_1/",
    "early_stopping_patience": 80,
    "freeze_mode": "none"
  },
  "wandb": {
    "project": "Breast-US-Segmentation",
    "disable": true
  },
  "system": {
    "seed": 42
  },
  "usfm_args": {
    "decoder_type": "UPerHead",
    "PRETRAIN_CKPT": "./pretrained_models/USFM_latest.pth",
    "mode": "local",
    "embed_dim": 768,
    "depth": 12,
    "num_heads": 12,
    "patch_size": 16,
    "drop_path_rate": 0.0
  }
}
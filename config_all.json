{
  "name": "BUS_USFM_Unified_Experiment",
  "n_gpu": 1,
  "arch": {
    "type": "USFM",
    "args": {
      "in_channels": 1,
      "out_channels": 1
    }
  },
  "data": {
    "datasets": ["busi"],
    "force_prepare": false,
    "target_size": 224,
    "batch_size": 16,
    "num_workers": 8,
    "use_pad": false
  },
  "script_defaults": {
    "local_target_size": 224,
    "official_target_size": 512,
    "note": "run_vit_4.sh uses this file as a template and overwrites name, arch.type, data.target_size, loss, trainer.checkpoint_dir, trainer.freeze_mode, and usfm_args per experiment."
  },
  "optimizer": {
    "type": "AdamW",
    "args": {
      "lr": 0.0001,
      "weight_decay": 1e-5
    }
  },
  "lr_scheduler": {
    "type": "CosineAnnealingLR",
    "args": {
      "T_max": 800,
      "eta_min": 1e-5
    }
  },
  "loss": {
    "type": "ATMLoss",
    "args": {
      "num_classes": 1,
      "dec_layers": 3,
      "mask_weight": 20.0,
      "dice_weight": 1.0,
      "cls_weight": 1.0
    }
  },
  "metrics": [
    "pixel_accuracy",
    "dice_score",
    "hd95_batch",
    "iou_score"
  ],
  "trainer": {
    "epochs": 800,
    "k_folds": 5,
    "checkpoint_dir": "checkpoints_unified/",
    "early_stopping_patience": 80,
    "freeze_mode": "none"
  },
  "wandb": {
    "project": "Breast-US-Segmentation",
    "disable": true
  },
  "system": {
    "seed": 42
  },
  "usfm_args": {
    "decoder_type": "SegViT",
    "mode": "official",
    "PRETRAIN_CKPT": "./pretrained_models/USFM_latest.pth",
    "drop_path_rate": 0.1,
    "base_lr": 3e-4,
    "warmup_lr": 5e-5,
    "min_lr": 0.0,
    "weight_decay": 0.05,
    "layer_decay": 0.65,
    "warmup_epochs": 20,
    "aux_weight": 0.4,
    "embed_dim": 768,
    "depth": 12,
    "num_heads": 12,
    "patch_size": 16
  }
}

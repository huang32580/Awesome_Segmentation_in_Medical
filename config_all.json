{
  "name": "BUS_USFM_Unified_Experiment",
  "n_gpu": 1,
  "arch": {
    "type": "USFM",
    "args": {
      "in_channels": 1,
      "out_channels": 1
    }
  },
  "data": {
    "datasets": ["busi"],
    "force_prepare": false,
    "target_size": 224,
    "batch_size": 16,
    "num_workers": 8,
    "use_pad": false
  },

  "//_说明_1": "【常规模式优化器】当 mode 为 local 或 local_aux 时，代码会启用下面这两个节点",
  "optimizer": {
    "type": "AdamW",
    "args": {
      "lr": 0.0001,
      "weight_decay": 1e-5
    }
  },
  "lr_scheduler": {
    "type": "CosineAnnealingLR",
    "args": {
      "T_max": 800,
      "eta_min": 1e-5
    }
  },

  "//_说明_2": "【损失函数切换】SegViT 必须配 ATMLoss；UPerHead 必须配 DiceBCELoss",
  "loss": {
    "type": "ATMLoss",
    "args": {
      "num_classes": 1,
      "dec_layers": 3,
      "mask_weight": 20.0,
      "dice_weight": 1.0,
      "cls_weight": 1.0
    }
  },

  "metrics": [
    "pixel_accuracy", "dice_score", "hd95_batch", "iou_score"
  ],
  "trainer": {
    "epochs": 800,
    "k_folds": 5,
    "checkpoint_dir": "checkpoints_unified/",
    "early_stopping_patience": 80,
    "freeze_mode": "none"
  },
  "wandb": {
    "project": "Breast-US-Segmentation",
    "disable": true
  },
  "system": {
    "seed": 42
  },

  "usfm_args": {
    "//_核心开关": "修改下面这两个参数来决定模型架构和运行模式",
    "decoder_type": "SegViT",
    "mode": "official",
    "PRETRAIN_CKPT": "./pretrained_models/USFM_latest.pth",
    "drop_path_rate": 0.1,

    "//_说明_3": "【官方模式超参数】当 mode 为 official 时，train.py 会自动启用以下参数来构建带 Warmup 的 LLRD 优化器",
    "base_lr": 3e-4,
    "warmup_lr": 5e-5,
    "min_lr": 0.0,
    "weight_decay": 0.05,
    "layer_decay": 0.65,
    "warmup_epochs": 20,
    "aux_weight": 0.4,

    "//_结构参数": "Backbone 基础参数，通常保持默认",
    "embed_dim": 768,
    "depth": 12,
    "num_heads": 12,
    "patch_size": 16
  }
}